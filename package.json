{
  "name": "chat-state-cloudflare-do",
  "version": "0.2.0",
  "description": "Cloudflare Durable Objects state adapter for Chat SDK",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "npm run test:unit && npm run test:workers",
    "test:unit": "vitest run",
    "test:workers": "vitest run --config vitest.workers.config.ts",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "typecheck:workers": "tsc --noEmit -p tsconfig.workers-tests.json",
    "typecheck:example": "npm --prefix example run typecheck",
    "clean": "rm -rf dist"
  },
  "peerDependencies": {
    "chat": "^4.26.0"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.17.0",
    "@cloudflare/workers-types": "^4.20260701.1",
    "@types/node": "^26.1.0",
    "chat": "^4.32.0",
    "tsup": "^8.3.5",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  },
  "overrides": {
    "esbuild": "^0.28.1"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dcartertwo/chat-state-cloudflare-do.git"
  },
  "homepage": "https://github.com/dcartertwo/chat-state-cloudflare-do#readme",
  "bugs": {
    "url": "https://github.com/dcartertwo/chat-state-cloudflare-do/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "chat-sdk",
    "chat-adapter",
    "state",
    "cloudflare",
    "durable-objects",
    "workers"
  ],
  "author": "Dan Carter",
  "license": "MIT"
}
