{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "chat-state-cloudflare-do-test",
  "main": "test/worker.ts",
  "compatibility_date": "2026-07-01",
  "durable_objects": {
    "bindings": [
      { "name": "CHAT_STATE", "class_name": "ChatStateDO" }
    ]
